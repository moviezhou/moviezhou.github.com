---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import PageHeader from '../../components/PageHeader.astro';
---

<BaseLayout
  title="Gallery"
  description="影像与碎片，未经整理的视觉"
  canonicalPath="/gallery.html"
  noindex={true}
>
  <Header slot="header" />
  <main class="reading">
    <PageHeader title="Gallery" subtitle="Fragments & stills" />

    <div class="empty-state gallery-empty reveal">
      <p class="empty-lead">相册还在整理中。</p>
      <p>这里会放照片、截图与视觉碎片。如果你有想保留的旧图，可以告诉我，我会补进来。</p>
    </div>
  </main>
  <Footer slot="footer" />
</BaseLayout>
