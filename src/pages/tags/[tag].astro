---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import PageHeader from '../../components/PageHeader.astro';
import {
  formatListDate,
  postPath,
  postsForTag,
  primaryTag,
  publishedPosts,
  tagSlug,
  cjkSpacing,
  normaliseTag,
  type BlogPost,
} from '../../lib/posts';

export async function getStaticPaths() {
  const posts = publishedPosts(await getCollection('blog'));
  const labels = new Set<string>();

  for (const post of posts) {
    for (const tag of post.data.tags ?? []) {
      const label = normaliseTag(tag);
      if (label) labels.add(label);
    }
  }

  return [...labels].map((label) => ({
    params: { tag: tagSlug(label) },
    props: { label },
  }));
}

interface Props {
  label: string;
}

const { label } = Astro.props;
const posts = postsForTag(publishedPosts(await getCollection('blog')), label);
---

<BaseLayout
  title={`Tag · ${cjkSpacing(label)}`}
  description={`${cjkSpacing(label)} 相关的 ${posts.length} 篇文章`}
  canonicalPath={`/tags/${tagSlug(label)}.html`}
>
  <Header slot="header" />
  <main class="reading">
    <PageHeader
      title={cjkSpacing(label)}
      subtitle={`${posts.length} entries`}
      backHref="/tags.html"
      backLabel="All tags"
    />

    {
      posts.length ? (
        <div class="posts compact-list">
          {posts.map((post: BlogPost) => (
            <a class="post-row" href={postPath(post)}>
              <span class="date">{formatListDate(post.data.date)}</span>
              <span class="title">{cjkSpacing(post.data.title)}</span>
              <span class="tag">{primaryTag(post.data.tags)}</span>
            </a>
          ))}
        </div>
      ) : (
        <p class="empty-state">这个标签下还没有文章。</p>
      )
    }
  </main>
  <Footer slot="footer" />
</BaseLayout>
