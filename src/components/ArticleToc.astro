---
import { cjkSpacing } from '../lib/posts';

export interface TocHeading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  headings: TocHeading[];
}

const { headings } = Astro.props;
const items = headings.filter((h) => h.depth === 2 || h.depth === 3);
---

{
  items.length > 0 && (
    <aside class="article-toc" aria-label="Table of contents">
      <p class="article-toc__label">In this essay</p>
      <nav class="article-toc__nav">
        <ul>
          {items.map((h) => (
            <li class:list={['article-toc__item', { 'is-h3': h.depth === 3 }]}>
              <a href={`#${h.slug}`} data-toc-slug={h.slug}>
                {cjkSpacing(h.text)}
              </a>
            </li>
          ))}
        </ul>
      </nav>
    </aside>
  )
}

<script>
  const nav = document.querySelector('.article-toc__nav');
  if (nav) {
    const links = [...nav.querySelectorAll('a[data-toc-slug]')];
    const sections = links
      .map((a) => document.getElementById(a.dataset.tocSlug ?? ''))
      .filter((el) => el instanceof HTMLElement);

    if (sections.length) {
      /** Extra px below scroll-margin so a heading at the reading line still counts */
      const SLACK = 72;
      let navLock = null;

      function scrollMargin() {
        const topbar = document.getElementById('topbar');
        const bar = topbar?.getBoundingClientRect().height ?? 0;
        return Math.max(bar + 16, 90);
      }

      function setActive(id) {
        links.forEach((a) => a.classList.toggle('is-active', a.dataset.tocSlug === id));
      }

      function updateFromScroll() {
        if (navLock) return;
        const line = scrollMargin();
        let current = sections[0].id;
        for (const el of sections) {
          if (el.getBoundingClientRect().top <= line + SLACK) current = el.id;
        }
        setActive(current);
      }

      function syncFromHash() {
        const id = decodeURIComponent(location.hash.replace(/^#/, ''));
        if (id && sections.some((el) => el.id === id)) {
          setActive(id);
          return;
        }
        updateFromScroll();
      }

      function releaseNavLock() {
        navLock = null;
        syncFromHash();
      }

      links.forEach((a) => {
        a.addEventListener('click', () => {
          const id = a.dataset.tocSlug;
          if (!id) return;
          navLock = id;
          setActive(id);
          if (!('onscrollend' in window)) {
            setTimeout(releaseNavLock, 500);
          }
        });
      });

      addEventListener('hashchange', () => {
        navLock = null;
        syncFromHash();
      });

      if ('onscrollend' in window) {
        addEventListener('scrollend', () => {
          if (navLock) releaseNavLock();
          else updateFromScroll();
        });
      }

      let ticking = false;
      addEventListener(
        'scroll',
        () => {
          if (!ticking) {
            ticking = true;
            requestAnimationFrame(() => {
              updateFromScroll();
              ticking = false;
            });
          }
        },
        { passive: true },
      );

      syncFromHash();
    }
  }
</script>
