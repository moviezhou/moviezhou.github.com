---
import { cjkSpacing } from '../lib/posts';

export interface TocHeading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  headings: TocHeading[];
}

const { headings } = Astro.props;
const items = headings.filter((h) => h.depth === 2 || h.depth === 3);
---

{
  items.length > 0 && (
    <aside class="article-toc" aria-label="Table of contents">
      <p class="article-toc__label">In this essay</p>
      <nav class="article-toc__nav">
        <ul>
          {items.map((h) => (
            <li class:list={['article-toc__item', { 'is-h3': h.depth === 3 }]}>
              <a href={`#${h.slug}`} data-toc-slug={h.slug}>
                {cjkSpacing(h.text)}
              </a>
            </li>
          ))}
        </ul>
      </nav>
    </aside>
  )
}

<script>
  const nav = document.querySelector('.article-toc__nav');
  if (nav) {
    const links = [...nav.querySelectorAll('a[data-toc-slug]')];
    const sections = links
      .map((a) => document.getElementById(a.dataset.tocSlug ?? ''))
      .filter((el) => el instanceof HTMLElement);

    if (sections.length) {
      /** Extra px below the reading line so a heading sitting there still counts. */
      const SLACK = 72;
      /** While locked, ignore scroll-driven updates (e.g. during smooth scroll). */
      let locked = false;
      let unlockTimer = 0;

      function readingLine() {
        const topbar = document.getElementById('topbar');
        const bar = topbar?.getBoundingClientRect().height ?? 0;
        return Math.max(bar + 16, 90) + SLACK;
      }

      function setActive(id) {
        links.forEach((a) => a.classList.toggle('is-active', a.dataset.tocSlug === id));
      }

      function updateFromScroll() {
        if (locked) return;
        const line = readingLine();
        let current = sections[0].id;
        for (const el of sections) {
          if (el.getBoundingClientRect().top <= line) current = el.id;
        }
        setActive(current);
      }

      function lockTo(id) {
        locked = true;
        setActive(id);
        clearTimeout(unlockTimer);
        // Backstop in case scrollend never fires (heading already in view).
        unlockTimer = setTimeout(release, 700);
      }

      function release() {
        clearTimeout(unlockTimer);
        locked = false;
        updateFromScroll();
      }

      links.forEach((a) => {
        a.addEventListener('click', () => {
          const id = a.dataset.tocSlug;
          if (id) lockTo(id);
        });
      });

      addEventListener('hashchange', () => {
        const id = decodeURIComponent(location.hash.replace(/^#/, ''));
        if (id && sections.some((el) => el.id === id)) lockTo(id);
      });

      addEventListener('scrollend', release);

      let ticking = false;
      addEventListener(
        'scroll',
        () => {
          if (!ticking) {
            ticking = true;
            requestAnimationFrame(() => {
              updateFromScroll();
              ticking = false;
            });
          }
        },
        { passive: true },
      );

      const initial = decodeURIComponent(location.hash.replace(/^#/, ''));
      if (initial && sections.some((el) => el.id === initial)) lockTo(initial);
      else updateFromScroll();
    }
  }
</script>
