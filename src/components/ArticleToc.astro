---
import { cjkSpacing } from '../lib/posts';

export interface TocHeading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  headings: TocHeading[];
}

const { headings } = Astro.props;
const items = headings.filter((h) => h.depth === 2 || h.depth === 3);
const showMobile = items.length >= 2;
---

{
  items.length > 0 && (
    <>
      {
        showMobile ? (
          <details class="article-toc-mobile">
            <summary class="article-toc__label">In this essay</summary>
            <nav class="article-toc__nav" aria-label="Table of contents">
              <ul>
                {items.map((h) => (
                  <li class:list={['article-toc__item', { 'is-h3': h.depth === 3 }]}>
                    <a href={`#${h.slug}`} data-toc-slug={h.slug}>
                      {cjkSpacing(h.text)}
                    </a>
                  </li>
                ))}
              </ul>
            </nav>
          </details>
        ) : null
      }
      <aside class="article-toc" aria-label="Table of contents">
        <p class="article-toc__label">In this essay</p>
        <nav class="article-toc__nav">
          <ul>
            {items.map((h) => (
              <li class:list={['article-toc__item', { 'is-h3': h.depth === 3 }]}>
                <a href={`#${h.slug}`} data-toc-slug={h.slug}>
                  {cjkSpacing(h.text)}
                </a>
              </li>
            ))}
          </ul>
        </nav>
      </aside>
    </>
  )
}

<script>
  const links = [...document.querySelectorAll('a[data-toc-slug]')];
  if (links.length) {
    const sections = links
      .map((a) => document.getElementById(a.dataset.tocSlug ?? ''))
      .filter((el) => el instanceof HTMLElement);

    if (sections.length) {
      /** Extra px below the reading line so a heading sitting there still counts. */
      const SLACK = 72;
      /**
       * When the user clicks a TOC link the page smooth-scrolls; those scroll
       * events would otherwise drag the highlight back to a previous heading
       * (especially near the page bottom, where the target can't reach the top).
       * So we lock the highlight on click and only release on a genuine
       * user-initiated scroll gesture.
       */
      let locked = false;

      function readingLine() {
        const topbar = document.getElementById('topbar');
        const bar = topbar?.getBoundingClientRect().height ?? 0;
        return Math.max(bar + 16, 90) + SLACK;
      }

      function setActive(id) {
        links.forEach((a) => a.classList.toggle('is-active', a.dataset.tocSlug === id));
      }

      function currentByScroll() {
        const line = readingLine();
        const doc = document.documentElement;
        const atBottom = window.innerHeight + window.scrollY >= doc.scrollHeight - 4;
        let current = sections[0].id;
        for (const el of sections) {
          const top = el.getBoundingClientRect().top;
          if (top <= line) current = el.id;
          else if (atBottom && top <= window.innerHeight) current = el.id;
        }
        return current;
      }

      function updateFromScroll() {
        if (!locked) setActive(currentByScroll());
      }

      function lockTo(id) {
        locked = true;
        setActive(id);
      }

      function unlock() {
        if (locked) {
          locked = false;
          updateFromScroll();
        }
      }

      links.forEach((a) => {
        a.addEventListener('click', () => {
          const id = a.dataset.tocSlug;
          if (id) lockTo(id);
        });
      });

      addEventListener('hashchange', () => {
        const id = decodeURIComponent(location.hash.replace(/^#/, ''));
        if (id && sections.some((el) => el.id === id)) lockTo(id);
      });

      // Genuine user-driven scrolling releases the lock.
      addEventListener('wheel', unlock, { passive: true });
      addEventListener('touchstart', unlock, { passive: true });
      addEventListener('keydown', (e) => {
        const keys = ['ArrowUp', 'ArrowDown', 'PageUp', 'PageDown', 'Home', 'End', ' ', 'Spacebar'];
        if (keys.includes(e.key)) unlock();
      });

      let ticking = false;
      addEventListener(
        'scroll',
        () => {
          if (!ticking) {
            ticking = true;
            requestAnimationFrame(() => {
              updateFromScroll();
              ticking = false;
            });
          }
        },
        { passive: true },
      );

      const initial = decodeURIComponent(location.hash.replace(/^#/, ''));
      if (initial && sections.some((el) => el.id === initial)) lockTo(initial);
      else updateFromScroll();
    }
  }
</script>
